generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  address   String?
  package   String
  bill      Int
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Billing   Billing[]
}

model Package {
  id          Int      @id @default(autoincrement())
  name        String
  speed       String
  price       Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Billing {
  id         Int       @id @default(autoincrement())
  customerId Int
  amount     Int
  dueDate    DateTime
  status     String    @default("UNPAID")
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  Customer   Customer  @relation(fields: [customerId], references: [id])
}

model Voucher {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  packageName String
  duration    String
  price       Int
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
}

model Setting {
  id              Int      @id @default(autoincrement())
  ispName         String
  mikrotikHost    String?
  mikrotikUser    String?
  mikrotikPass    String?
  whatsappGateway String?
  smtpHost        String?
  smtpUser        String?
  smtpPass        String?
  logo            String?
  createdAt       DateTime @default(now())
}
